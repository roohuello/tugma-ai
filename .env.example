# Tugma-AI — SSHS Elective Matcher
# ================================
#
# Copy to .env and fill in values.
# cp .env.example .env

# --- LLM Provider (OpenAI-compatible) ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# --- Jina AI (Embeddings + Reranker) ---
JINA_API_KEY=jina_...

# --- Qdrant ---
QDRANT_URL=https://your-cluster.qdrant.cloud
QDRANT_API_KEY=...

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LangFuse ---
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Guardrails AI ---
# Optional: set if using Guardrails Hub validators requiring a token
GUARDRAILS_TOKEN=

# --- App ---
ENVIRONMENT=development          # development | production
MAX_INTAKE_EXCHANGES=6           # Max profiling Q&A rounds
SESSION_TTL_MINUTES=30           # Redis state expiry
